# Helix CRM — local environment template.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# n8n production webhook for the Helix Lab Recs Sync workflow.
N8N_WEBHOOK_URL=http://localhost:5678/webhook/helix-lab-recs

# Supabase project (REST API base, no trailing slash).
